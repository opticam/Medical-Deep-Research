# ============================================================
# Medical Deep Research Agent — Environment Configuration
# Copy this to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ----------------------------
# Google Cloud / Vertex AI
# ----------------------------
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# GCS bucket for Agent Engine staging (will be created if it doesn't exist)
STAGING_BUCKET=gs://your-project-id-medical-research-staging

# ----------------------------
# Medical Data APIs
# ----------------------------

# NCBI/PubMed API Key (optional — increases rate limit from 3/sec to 10/sec)
# Get free key at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# FDA openFDA API Key (optional — increases rate limit from 240/min to 1000/min)
# Get free key at: https://open.fda.gov/apis/authentication/
FDA_API_KEY=

# ----------------------------
# Local Development Only
# (not used in Vertex AI Agent Engine deployment)
# ----------------------------

# Use this INSTEAD of Vertex AI for local testing with AI Studio
# GOOGLE_API_KEY=your-ai-studio-api-key
# GOOGLE_GENAI_USE_VERTEXAI=FALSE
